---
import { useTranslations, type Locale } from "../i18n/utils";

interface Props {
  lang?: Locale;
}

const { lang = "es" } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="mt-auto bg-charcoal text-cream px-6 py-12 md:px-16 md:py-16">
  <div class="max-w-5xl mx-auto text-center">
    <p class="font-serif text-2xl mb-2">El Rabón Farm</p>
    <p class="text-cream/60 text-sm mb-6">{t("footer.tagline")}</p>
    <p class="text-cream/40 text-xs">&copy; {year} El Rabón Farm. {t("footer.rights")}</p>
  </div>
</footer>
