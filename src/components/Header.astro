---
import { useTranslations, type Locale } from "../i18n/utils";

interface Props {
  lang?: Locale;
}

const { lang = "es" } = Astro.props;
const t = useTranslations(lang);

const otherLang: Locale = lang === "es" ? "en" : "es";
const pathname = Astro.url.pathname;
// Replace the /es/ or /en/ prefix to build the alternate language URL
const pathWithoutLang = pathname.replace(/^\/(es|en)(\/|$)/, "/");
const switchUrl = `/${otherLang}${pathWithoutLang === "/" ? "" : pathWithoutLang}`;

const navLinks = [
  { href: `/${lang}`, label: t("nav.home") },
  { href: `/${lang}/gallery`, label: t("nav.gallery") },
  { href: `/${lang}/contact`, label: t("nav.contact") },
];
---

<header
  id="site-header"
  class="fixed top-0 left-0 w-full z-50 transition-all duration-300 bg-charcoal/90 backdrop-blur-md shadow-lg"
>
  <nav class="flex items-center justify-between px-6 py-4 md:px-16">
    <a href={`/${lang}`} class="font-serif text-2xl text-cream no-underline">
      El Rabón
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-8">
      <ul class="flex items-center gap-8 list-none m-0 p-0">
        {navLinks.map(({ href, label }) => {
          const isActive = pathname === href || (href !== `/${lang}` && pathname.startsWith(href));
          return (
            <li>
              <a
                href={href}
                class:list={[
                  "text-cream/80 no-underline text-sm tracking-wide uppercase transition-colors hover:text-cream",
                  { "!text-cream font-semibold": isActive },
                ]}
              >
                {label}
              </a>
            </li>
          );
        })}
      </ul>

      <!-- Language switcher -->
      <a
        href={switchUrl}
        class="text-cream/60 hover:text-cream text-xs tracking-widest uppercase border border-cream/30 hover:border-cream/60 rounded px-2 py-1 transition-colors no-underline"
        aria-label={`Switch to ${otherLang === "en" ? "English" : "Español"}`}
      >
        {otherLang === "en" ? "EN" : "ES"}
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="md:hidden flex flex-col justify-center items-center gap-1.5 w-11 h-11 bg-transparent border-none cursor-pointer"
      aria-label={t("nav.toggle")}
      aria-expanded="false"
    >
      <span class="block w-6 h-0.5 bg-cream transition-all duration-300 origin-center" />
      <span class="block w-6 h-0.5 bg-cream transition-all duration-300" />
      <span class="block w-6 h-0.5 bg-cream transition-all duration-300 origin-center" />
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden overflow-hidden max-h-0 transition-all duration-300"
  >
    <ul class="flex flex-col items-center gap-6 py-8 list-none m-0 px-6">
      {navLinks.map(({ href, label }) => {
        const isActive = pathname === href || (href !== `/${lang}` && pathname.startsWith(href));
        return (
          <li>
            <a
              href={href}
              class:list={[
                "text-cream/80 no-underline text-lg tracking-wide uppercase transition-colors hover:text-cream py-2",
                { "!text-cream font-semibold": isActive },
              ]}
            >
              {label}
            </a>
          </li>
        );
      })}
      <!-- Language switcher in mobile menu -->
      <li>
        <a
          href={switchUrl}
          class="text-cream/60 hover:text-cream text-sm tracking-widest uppercase border border-cream/30 hover:border-cream/60 rounded px-3 py-2 transition-colors no-underline"
        >
          {otherLang === "en" ? "English" : "Español"}
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const header = document.getElementById("site-header")!;
  const toggle = document.getElementById("menu-toggle")!;
  const menu = document.getElementById("mobile-menu")!;
  const bars = toggle.querySelectorAll("span");

  // Scroll: transparent header only on home page over the hero
  const hasHero = !!document.querySelector("section.h-screen");

  function onScroll() {
    if (!hasHero || window.scrollY > 50) {
      header.classList.add("bg-charcoal/90", "backdrop-blur-md", "shadow-lg");
    } else {
      header.classList.remove("bg-charcoal/90", "backdrop-blur-md", "shadow-lg");
    }
  }
  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();

  // Mobile menu toggle
  let open = false;
  toggle.addEventListener("click", () => {
    open = !open;
    toggle.setAttribute("aria-expanded", String(open));

    if (open) {
      menu.style.maxHeight = menu.scrollHeight + "px";
      bars[0].style.transform = "rotate(45deg) translate(3px, 3px)";
      bars[1].style.opacity = "0";
      bars[2].style.transform = "rotate(-45deg) translate(3px, -3px)";
    } else {
      menu.style.maxHeight = "0";
      bars[0].style.transform = "";
      bars[1].style.opacity = "";
      bars[2].style.transform = "";
    }
  });
</script>
