---
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations, locales, type Locale } from "../../i18n/utils";
import heroImage from "../../assets/images/hero-deck-ocean.jpg";
import aboutImage from "../../assets/images/about-stone-cottage.jpg";
import galleryPreview1 from "../../assets/images/gallery-farm-landscape.jpg";
import galleryPreview2 from "../../assets/images/gallery-hillside-view.jpg";
import galleryPreview3 from "../../assets/images/gallery-farm-grounds.jpg";
import galleryPreview4 from "../../assets/images/gallery-countryside-1.jpg";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const t = useTranslations(lang);

const previewImages = [
  { src: galleryPreview1, alt: "Farm landscape" },
  { src: galleryPreview2, alt: "Hillside view" },
  { src: galleryPreview3, alt: "Farm grounds" },
  { src: galleryPreview4, alt: "Countryside" },
];
---

<BaseLayout title={t("meta.home.title")} description={t("meta.home.description")} lang={lang}>
  <main>
    <!-- Hero Section -->
    <section class="relative h-screen flex items-center justify-center overflow-hidden">
      <!-- Cel-shading SVG filter: posterization + edge sharpening -->
      <svg class="absolute w-0 h-0" aria-hidden="true">
        <defs>
          <filter id="cel-shade" color-interpolation-filters="sRGB">
            <!-- Posterize: reduce color levels for flat cel-shaded look -->
            <feComponentTransfer>
              <feFuncR type="discrete" tableValues="0 0.15 0.3 0.45 0.6 0.75 0.9 1" />
              <feFuncG type="discrete" tableValues="0 0.15 0.3 0.45 0.6 0.75 0.9 1" />
              <feFuncB type="discrete" tableValues="0 0.15 0.3 0.45 0.6 0.75 0.9 1" />
            </feComponentTransfer>
            <!-- Sharpen edges for outlined look -->
            <feConvolveMatrix
              order="3"
              kernelMatrix="0 -0.5 0 -0.5 3 -0.5 0 -0.5 0"
              preserveAlpha="true"
            />
          </filter>
        </defs>
      </svg>

      <Image
        src={heroImage}
        alt="El Rabón Farm landscape"
        class="absolute inset-0 w-full h-full object-cover scale-110"
        id="hero-parallax-img"
        style="filter: url(#cel-shade);"
        widths={[640, 1024, 1440, 2400]}
        sizes="100vw"
        loading="eager"
        quality={70}
        format="webp"
      />
      <div class="absolute inset-0 bg-black/30"></div>

      <div class="relative z-10 text-center px-6 md:px-12 lg:px-16">
        <h1 class="text-4xl md:text-5xl lg:text-6xl text-cream drop-shadow-lg mb-4">
          El Rabón Farm
        </h1>
        <p class="text-cream/80 text-lg md:text-xl max-w-2xl mx-auto drop-shadow">
          {t("hero.tagline")}
        </p>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-8 h-8 text-cream/60"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </div>
    </section>

    <!-- About Preview -->
    <section class="px-6 py-16 md:px-12 md:py-32">
      <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 items-center">
        <Image
          src={aboutImage}
          alt="The farm and its surroundings"
          class="aspect-[4/3] rounded-lg overflow-hidden object-cover w-full"
          widths={[640, 800, 1200]}
          sizes="(min-width: 768px) 50vw, 100vw"
          quality={75}
          format="webp"
        />

        <div>
          <h2 class="text-3xl md:text-4xl mb-6">{t("about.heading")}</h2>
          <p class="text-charcoal/80 leading-relaxed mb-4">{t("about.p1")}</p>
          <p class="text-charcoal/80 leading-relaxed mb-4">{t("about.p2")}</p>
          <p class="text-charcoal/80 leading-relaxed">{t("about.p3")}</p>
        </div>
      </div>
    </section>

    <!-- Gallery Preview -->
    <section class="px-6 py-16 md:px-12 md:py-32 lg:px-16 bg-warm-white">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl md:text-4xl text-center mb-10 md:mb-16">{t("gallery.preview.heading")}</h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 lg:gap-8">
          {previewImages.map(({ src, alt }) => (
            <div class="aspect-[4/3] rounded-lg overflow-hidden transition-all duration-300 hover:scale-105 hover:shadow-lg cursor-pointer">
              <Image
                src={src}
                alt={alt}
                class="w-full h-full object-cover"
                widths={[320, 480, 640]}
                sizes="(min-width: 1024px) 25vw, (min-width: 640px) 50vw, 100vw"
                quality={75}
                format="webp"
              />
            </div>
          ))}
        </div>

        <div class="text-center mt-10 md:mt-16">
          <a
            href={`/${lang}/gallery`}
            class="inline-block text-forest font-medium hover:text-bark transition-colors underline underline-offset-4"
          >
            {t("gallery.preview.link")}
          </a>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="px-6 py-16 md:px-16 md:py-24 bg-sand">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-2xl md:text-3xl mb-6">{t("cta.heading")}</h2>
        <p class="text-charcoal/70 leading-relaxed mb-8 md:mb-10">{t("cta.text")}</p>
        <a
          href={`/${lang}/contact`}
          class="inline-block w-full md:w-auto px-8 py-3 bg-forest text-cream rounded-lg font-medium text-center transition-colors hover:bg-forest/80"
        >
          {t("cta.button")}
        </a>
      </div>
    </section>
  </main>

  <script>
    const img = document.getElementById("hero-parallax-img") as HTMLElement | null;
    if (img) {
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (!prefersReducedMotion) {
        const isTouch = "ontouchstart" in window || navigator.maxTouchPoints > 0;
        const factor = isTouch ? 0.15 : 0.35;
        let ticking = false;

        window.addEventListener(
          "scroll",
          () => {
            if (!ticking) {
              ticking = true;
              requestAnimationFrame(() => {
                const scrollY = window.scrollY;
                img.style.transform = `scale(1.1) translateY(${scrollY * factor}px)`;
                ticking = false;
              });
            }
          },
          { passive: true }
        );
      }
    }
  </script>
</BaseLayout>
