---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContactForm from "../../components/ContactForm.tsx";
import { useTranslations, getContactFormTranslations, locales, type Locale } from "../../i18n/utils";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const t = useTranslations(lang);
const formTranslations = getContactFormTranslations(t);
---

<BaseLayout title={t("meta.contact.title")} description={t("meta.contact.description")} lang={lang}>
  <main class="pt-24">
    <section class="px-6 py-16 md:px-16 md:py-32">
      <div class="max-w-6xl mx-auto">
        <h1 class="text-3xl md:text-4xl text-center mb-10 md:mb-16">{t("contact.title")}</h1>

        <div class="grid grid-cols-1 md:grid-cols-[2fr_1fr] gap-8 md:gap-16">
          <!-- Contact Form -->
          <div>
            <ContactForm client:load translations={formTranslations} />
          </div>

          <!-- Farm info -->
          <div>
            <h2 class="text-xl mb-6">{t("contact.visit")}</h2>

            <div class="mb-6">
              <h3 class="text-sm font-sans font-semibold uppercase tracking-wide text-charcoal/50 mb-2">{t("contact.address.label")}</h3>
              <a href="https://maps.app.goo.gl/u9VCo6Y6aEijXpWp6" target="_blank" rel="noopener noreferrer" class="text-forest hover:text-bark transition-colors leading-relaxed inline-block py-1">
                El Rabón<br />
                El Pino, Las Cuevecitas<br />
                38540 Candelaria<br />
                Santa Cruz de Tenerife<br />
                Canarias, España
              </a>
            </div>

            <div class="mb-6">
              <h3 class="text-sm font-sans font-semibold uppercase tracking-wide text-charcoal/50 mb-2">{t("contact.email.label")}</h3>
              <a href="mailto:info@elrabonfarm.com" class="text-forest hover:text-bark transition-colors inline-block py-1">
                info@elrabonfarm.com
              </a>
            </div>

            <div class="mb-8">
              <h3 class="text-sm font-sans font-semibold uppercase tracking-wide text-charcoal/50 mb-2">{t("contact.phone.label")}</h3>
              <a href="tel:+521234567890" class="text-forest hover:text-bark transition-colors inline-block py-1">
                +52 123 456 7890
              </a>
            </div>

            <!-- Embedded map -->
            <div class="aspect-[4/3] rounded-lg overflow-hidden">
              <iframe
                src="https://maps.google.com/maps?q=28.366179,-16.412216&t=&z=15&ie=UTF8&iwloc=&output=embed"
                width="100%"
                height="100%"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="El Rabón Farm location"
              ></iframe>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
