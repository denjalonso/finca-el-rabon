---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="El Rabón Farm" description="A beautiful farm venue for weddings, events, and celebrations surrounded by nature.">
  <main>
    <!-- Hero Section -->
    <section class="relative h-screen flex items-center justify-center overflow-hidden">
      <!-- Background placeholder (replace with <Image> when assets are added) -->
      <div class="absolute inset-0 bg-gradient-to-b from-bark to-charcoal"></div>
      <div class="absolute inset-0 bg-black/30"></div>

      <div class="relative z-10 text-center px-6 md:px-12 lg:px-16">
        <h1 class="text-4xl md:text-5xl lg:text-6xl text-cream drop-shadow-lg mb-4">
          El Rabón Farm
        </h1>
        <p class="text-cream/80 text-lg md:text-xl max-w-2xl mx-auto drop-shadow">
          A place where nature meets celebration
        </p>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-8 h-8 text-cream/60"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </div>
    </section>

    <!-- About Preview -->
    <section class="px-6 py-16 md:px-12 md:py-32">
      <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 items-center">
        <!-- Image placeholder (replace with Astro <Image> when assets are added) -->
        <div class="aspect-[4/3] rounded-lg overflow-hidden bg-gradient-to-br from-sage to-moss"></div>

        <div>
          <h2 class="text-3xl md:text-4xl mb-6">Our Story</h2>
          <p class="text-charcoal/80 leading-relaxed mb-4">
            Nestled among rolling hills and ancient trees, El Rabón Farm is a place where the beauty of nature creates the perfect backdrop for life's most meaningful moments.
          </p>
          <p class="text-charcoal/80 leading-relaxed mb-4">
            Our family has cared for this land for generations, cultivating not just crops but a deep connection to the earth and the community around us.
          </p>
          <p class="text-charcoal/80 leading-relaxed">
            Today, we open our doors to those seeking a venue that feels both timeless and alive — a place where celebrations become memories woven into the landscape itself.
          </p>
        </div>
      </div>
    </section>

    <!-- Gallery Preview -->
    <section class="px-6 py-16 md:px-12 md:py-32 lg:px-16 bg-warm-white">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl md:text-4xl text-center mb-10 md:mb-16">A Glimpse of the Farm</h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 lg:gap-8">
          {[
            { from: "from-earth", to: "to-clay" },
            { from: "from-sage", to: "to-forest" },
            { from: "from-bark", to: "to-earth" },
            { from: "from-moss", to: "to-sage" },
          ].map(({ from, to }) => (
            <div class={`aspect-[4/3] rounded-lg overflow-hidden bg-gradient-to-br ${from} ${to} transition-all duration-300 hover:scale-105 hover:shadow-lg cursor-pointer`} />
          ))}
        </div>

        <div class="text-center mt-10 md:mt-16">
          <a
            href="/gallery"
            class="inline-block text-forest font-medium hover:text-bark transition-colors underline underline-offset-4"
          >
            View Full Gallery &rarr;
          </a>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="px-6 py-16 md:px-16 md:py-24 bg-sand">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-2xl md:text-3xl mb-6">Host Your Next Event at El Rabón</h2>
        <p class="text-charcoal/70 leading-relaxed mb-8 md:mb-10">
          From intimate gatherings to grand celebrations, our farm provides a one-of-a-kind setting for weddings, corporate events, and private parties.
        </p>
        <a
          href="/contact"
          class="inline-block w-full md:w-auto px-8 py-3 bg-forest text-cream rounded-lg font-medium text-center transition-colors hover:bg-forest/80"
        >
          Get in Touch
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
