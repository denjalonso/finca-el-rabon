---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import Lightbox from "../components/Lightbox";
import farmLandscape from "../assets/images/gallery-farm-landscape.jpg";
import hillsideView from "../assets/images/gallery-hillside-view.jpg";
import farmGrounds from "../assets/images/gallery-farm-grounds.jpg";
import countryside1 from "../assets/images/gallery-countryside-1.jpg";
import countryside2 from "../assets/images/gallery-countryside-2.jpg";
import countryside3 from "../assets/images/gallery-countryside-3.jpg";
import countryside4 from "../assets/images/gallery-countryside-4.jpg";

const images = [
  { src: farmLandscape, alt: "Farm landscape" },
  { src: hillsideView, alt: "Hillside view" },
  { src: farmGrounds, alt: "Farm grounds" },
  { src: countryside1, alt: "El Rabón countryside" },
  { src: countryside2, alt: "El Rabón countryside views" },
  { src: countryside3, alt: "Farm countryside scenery" },
  { src: countryside4, alt: "Farm scenic views" },
];

const lightboxImages = images.map(({ src, alt }) => ({
  src: src.src,
  alt,
}));
---

<BaseLayout title="Gallery — El Rabón Farm" description="Browse photos of El Rabón Farm's stunning landscapes, venues, and event spaces.">
  <main class="pt-24">
    <section class="px-6 py-16 sm:px-8 md:px-12 lg:px-16">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-10 md:mb-16">
          <h1 class="text-3xl md:text-4xl mb-4">Gallery</h1>
          <p class="text-charcoal/60 max-w-xl mx-auto">
            Explore the beauty of El Rabón Farm through our collection of photos.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 lg:gap-6">
          {images.map(({ src, alt }, index) => (
            <button
              type="button"
              class="aspect-[4/3] rounded-lg overflow-hidden shadow-sm transition-all duration-300 hover:scale-105 hover:shadow-lg cursor-pointer border-none p-0"
              data-lightbox-index={index}
              aria-label={`View ${alt}`}
            >
              <Image
                src={src}
                alt={alt}
                class="w-full h-full object-cover"
                widths={[320, 480, 640]}
                sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
                loading={index < 3 ? "eager" : "lazy"}
              />
            </button>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Lightbox client:load images={lightboxImages} />
</BaseLayout>
